{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stratton.cologne/schemas/tenant-installer/module-package.schema.json",
  "title": "Tenant Module Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "slug",
    "version"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string"
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "public_path": {
          "type": "string"
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "module_path": {
          "type": "string"
        }
      }
    }
  }
}
