<Window x:Class="TenantInstaller.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tenant Installer"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="28">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Tenant Installer"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#19324D" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Windows Setup Wizard fuer das Tenant-Basissystem."
                               TextWrapping="Wrap"
                               Foreground="#4E647B" />
                </StackPanel>

                <ListBox x:Name="StepList"
                         Margin="0,28,0,0"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="StepList_OnSelectionChanged">
                    <ListBoxItem Content="1. Willkommen" />
                    <ListBoxItem Content="2. Basisdaten" />
                    <ListBoxItem Content="3. Datenbank" />
                    <ListBoxItem Content="4. SMTP" />
                    <ListBoxItem Content="5. Quelle &amp; Prüfung" />
                    <ListBoxItem Content="6. Zusammenfassung" />
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl x:Name="WizardTabs"
                        Grid.Row="0"
                        Margin="0"
                        BorderThickness="0"
                        Background="White">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </TabControl.Resources>

                <TabItem>
                    <Grid Margin="36">
                        <StackPanel MaxWidth="640">
                            <TextBlock Text="Willkommen"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Dieser Wizard sammelt die Installationsdaten und bereitet den Windows-Installationslauf fuer das Tenant-System vor."
                                       TextWrapping="Wrap"
                                       Foreground="#4E647B" />
                            <Border Margin="0,28,0,0"
                                    Padding="18"
                                    CornerRadius="8"
                                    Background="#F8FAFD"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Aktueller Stand" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Die GUI nutzt die vorhandenen PowerShell-Skripte als Engine und bereitet den spaeteren EXE-Installer vor."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="36" MaxWidth="680">
                            <TextBlock Text="Basisdaten"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Installationspfad, Domain und Administrator-Zugang."
                                       Foreground="#4E647B" />

                            <TextBlock Margin="0,28,0,6" Text="Application Root" />
                            <TextBox x:Name="AppRootTextBox" Text="C:\TenantPlatform" />

                            <TextBlock Margin="0,18,0,6" Text="Primary Domain" />
                            <TextBox x:Name="DomainTextBox" />

                            <CheckBox x:Name="UseSslCheckBox"
                                      Margin="0,18,0,0"
                                      IsChecked="True"
                                      Content="SSL aktivieren" />

                            <TextBlock Margin="0,18,0,6" Text="Admin E-Mail" />
                            <TextBox x:Name="AdminEmailTextBox" />

                            <TextBlock Margin="0,18,0,6" Text="Admin Passwort" />
                            <PasswordBox x:Name="AdminPasswordBox" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="36" MaxWidth="680">
                            <TextBlock Text="Datenbank"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Verbindungsdaten fuer MySQL oder MariaDB."
                                       Foreground="#4E647B" />

                            <TextBlock Margin="0,28,0,6" Text="DB Host" />
                            <TextBox x:Name="DbHostTextBox" Text="127.0.0.1" />

                            <TextBlock Margin="0,18,0,6" Text="DB Port" />
                            <TextBox x:Name="DbPortTextBox" Text="3306" />

                            <TextBlock Margin="0,18,0,6" Text="DB Name" />
                            <TextBox x:Name="DbNameTextBox" Text="tenant_platform" />

                            <TextBlock Margin="0,18,0,6" Text="DB User" />
                            <TextBox x:Name="DbUserTextBox" Text="tenant_user" />

                            <TextBlock Margin="0,18,0,6" Text="DB Passwort" />
                            <PasswordBox x:Name="DbPasswordBox" />

                            <CheckBox x:Name="RunSeedersCheckBox"
                                      Margin="0,18,0,0"
                                      Content="Seeder nach Migrationen ausfuehren" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="36" MaxWidth="680">
                            <TextBlock Text="SMTP"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Optionale Mail-Konfiguration fuer den Tenant."
                                       Foreground="#4E647B" />

                            <CheckBox x:Name="EnableSmtpCheckBox"
                                      Margin="0,28,0,0"
                                      Content="SMTP konfigurieren"
                                      Checked="EnableSmtpCheckBox_OnChanged"
                                      Unchecked="EnableSmtpCheckBox_OnChanged" />

                            <TextBlock Margin="0,18,0,6" Text="SMTP Host" />
                            <TextBox x:Name="MailHostTextBox" IsEnabled="False" />

                            <TextBlock Margin="0,18,0,6" Text="SMTP Port" />
                            <TextBox x:Name="MailPortTextBox" Text="587" IsEnabled="False" />

                            <TextBlock Margin="0,18,0,6" Text="SMTP User" />
                            <TextBox x:Name="MailUsernameTextBox" IsEnabled="False" />

                            <TextBlock Margin="0,18,0,6" Text="SMTP Passwort" />
                            <PasswordBox x:Name="MailPasswordBox" IsEnabled="False" />

                            <TextBlock Margin="0,18,0,6" Text="SMTP Encryption" />
                            <TextBox x:Name="MailEncryptionTextBox" Text="tls" IsEnabled="False" />

                            <TextBlock Margin="0,18,0,6" Text="Mail From Address" />
                            <TextBox x:Name="MailFromAddressTextBox" IsEnabled="False" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="36" MaxWidth="760">
                            <TextBlock Text="Quelle &amp; Prüfung"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Waehle lokale Artefakte oder eine externe Release-Basis."
                                       Foreground="#4E647B" />

                            <TextBlock Margin="0,28,0,6" Text="Asset Base URL (optional)" />
                            <TextBox x:Name="AssetBaseUrlTextBox" />

                            <TextBlock Margin="0,18,0,6" Text="Tenant ID (optional)" />
                            <TextBox x:Name="TenantIdTextBox" />

                            <TextBlock Margin="0,18,0,6" Text="Lizenzkey (optional)" />
                            <TextBox x:Name="LicenseKeyTextBox" />

                            <CheckBox x:Name="DryRunCheckBox"
                                      Margin="0,18,0,0"
                                      Content="Installationslauf als Dry-Run vorbereiten" />

                            <Border Margin="0,28,0,0"
                                    Padding="18"
                                    CornerRadius="8"
                                    Background="#F8FAFD"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Vorbereitete Befehle" />
                                    <TextBlock Margin="0,10,0,4" FontWeight="SemiBold" Text="Preflight" />
                                    <TextBox x:Name="PreflightCommandTextBox"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             MinHeight="58" />
                                    <TextBlock Margin="0,14,0,4" FontWeight="SemiBold" Text="Install" />
                                    <TextBox x:Name="InstallCommandTextBox"
                                             IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     MinHeight="78" />
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                                <Button x:Name="RunPreflightButton"
                                        Width="160"
                                        Height="40"
                                        Content="Preflight starten"
                                        Click="RunPreflightButton_OnClick" />
                                <Button x:Name="RunInstallButton"
                                        Width="160"
                                        Height="40"
                                        Margin="12,0,0,0"
                                        Content="Install starten"
                                        Click="RunInstallButton_OnClick" />
                                <TextBlock x:Name="ExecutionStatusTextBlock"
                                           Margin="18,10,0,0"
                                           Foreground="#4E647B"
                                           Text="Noch kein Lauf ausgefuehrt." />
                            </StackPanel>

                            <ProgressBar x:Name="ExecutionProgressBar"
                                         Margin="0,14,0,0"
                                         Height="10"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0" />
                            <TextBlock x:Name="ExecutionPhaseTextBlock"
                                       Margin="0,8,0,0"
                                       Foreground="#4E647B"
                                       Text="Noch keine Phase aktiv." />

                            <TextBlock Margin="0,22,0,6" Text="Live-Ausgabe" FontWeight="SemiBold" />
                            <TextBox x:Name="ExecutionLogTextBox"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="220" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem>
                    <Grid Margin="36">
                        <StackPanel MaxWidth="760">
                            <TextBlock Text="Zusammenfassung"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#19324D" />
                            <TextBlock Margin="0,14,0,0"
                                       Text="Diese Ansicht zeigt die zusammengefassten Werte sowie die vorbereitete Windows-Engine-Ausfuehrung."
                                       Foreground="#4E647B"
                                       TextWrapping="Wrap" />

                            <TextBox x:Name="SummaryTextBox"
                                     Margin="0,24,0,0"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="340" />

                            <Border x:Name="ExecutionResultBorder"
                                    Margin="0,24,0,0"
                                    Padding="18"
                                    CornerRadius="8"
                                    Background="#F8FAFD"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="ExecutionResultTitleTextBlock"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#19324D"
                                               Text="Noch kein Installationslauf ausgefuehrt" />
                                    <TextBlock x:Name="ExecutionResultMessageTextBlock"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#4E647B"
                                               Text="Fuehre Preflight oder Install im Schritt 'Quelle &amp; Pruefung' aus. Das Ergebnis wird hier als finaler Success- oder Error-Screen zusammengefasst." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Background="White"
                    Padding="24">
                <DockPanel>
                    <Button x:Name="BackButton"
                            Width="120"
                            Height="40"
                            Content="Zurueck"
                            Click="BackButton_OnClick"
                            DockPanel.Dock="Left" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="RefreshButton"
                                Width="140"
                                Height="40"
                                Margin="0,0,12,0"
                                Content="Vorschau aktualisieren"
                                Click="RefreshButton_OnClick" />
                        <Button x:Name="NextButton"
                                Width="120"
                                Height="40"
                                Content="Weiter"
                                Click="NextButton_OnClick" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
